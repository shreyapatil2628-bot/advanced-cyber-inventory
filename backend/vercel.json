{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/login.html", "dest": "frontend/login.html" },
    { "src": "/add-item.html", "dest": "frontend/add-item.html" },
    { "src": "/update-item.html", "dest": "frontend/update-item.html" },
    { "src": "/report.html", "dest": "frontend/report.html" },
    { "src": "/", "dest": "frontend/login.html" }
  ]
}